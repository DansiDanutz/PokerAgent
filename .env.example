# Poker Agent environment.
# The app runs out-of-the-box with an in-memory seeded data source.
# Set these to switch to a live Supabase backend (DATA_DRIVER=supabase).

DATA_DRIVER=memory                 # memory | supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
