# Poker Agent environment.
# The app runs out-of-the-box with an in-memory seeded data source.
# Set these to switch to a live Supabase backend (DATA_DRIVER=supabase).

DATA_DRIVER=memory                 # memory | supabase
# Poker Agent's Supabase data lives in the "Games" project, pa_* tables.
NEXT_PUBLIC_SUPABASE_URL=https://lxhjfdxowpxzrybxdasi.supabase.co
# SECRET — server-only. Get it from Supabase dashboard → Project Settings →
# API → service_role key. Never commit it. Used only on the server.
SUPABASE_SERVICE_ROLE_KEY=

# --- ClubGG club (clubgg.com) ---
# Numeric Club ID from the ClubGG app (Clubs → your club → ID under the name).
NEXT_PUBLIC_CLUBGG_CLUB_ID=358346
NEXT_PUBLIC_CLUBGG_CLUB_NAME=Players Poker
NEXT_PUBLIC_CLUBGG_UNION_NAME=
NEXT_PUBLIC_CLUBGG_INVITE_LINK=https://clubgg.app.link/mzgF64Tyo4b
# Rake chain shares (union / club / agent) — agent share funds rakeback.
NEXT_PUBLIC_CLUBGG_RAKE_UNION=0.1
NEXT_PUBLIC_CLUBGG_RAKE_CLUB=0.3
NEXT_PUBLIC_CLUBGG_RAKE_AGENT=0.2
